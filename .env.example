# Instance ("prod" or "dev")
INSTANCE_ID=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_USER_ID=

# Database (Neon Postgres)
DATABASE_URL=

# GitHub
GH_TOKEN=

# AI keys (inherited by pi instances)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
FIREWORKS_API_KEY=

# Pi model (global default)
PI_MODEL=openai/gpt-5.5

# Per-stage model overrides (optional -- falls back to PI_MODEL)
# PI_MODEL_PLANNER=fireworks/accounts/fireworks/models/minimax-m2p7
# PI_MODEL_IMPLEMENTER=fireworks/accounts/fireworks/models/minimax-m2p7
# PI_MODEL_REVIEWER=openai/gpt-5.5
# PI_MODEL_PR_CREATOR=openai/gpt-5.5
# PI_MODEL_REVISION=fireworks/accounts/fireworks/models/minimax-m2p7
# PI_MODEL_MEMORY=openai/gpt-5.5
# PI_MODEL_PR_IMPACT=fireworks/accounts/fireworks/models/minimax-m2p7
# PI_MODEL_PR_ANALYST=fireworks/accounts/fireworks/models/minimax-m2p7
# PI_MODEL_PR_DISPLAY=fireworks/accounts/fireworks/models/minimax-m2p7

# Registered repos (JSON: name -> { localPath, githubUrl? })
# Set paths for THIS device -- they get synced to the DB on startup
REGISTERED_REPOS={"coliseum":{"localPath":"/path/to/coliseum","githubUrl":"https://github.com/user/coliseum.git"}}

# Real pipeline E2E smoke tests (optional; creates real PRs)
# E2E_REPO=pantheon
# E2E_PROMPT=

# Server
PORT=3333
HOST=0.0.0.0

# Observability (optional; unset the token to disable)
LOGFIRE_TOKEN=
