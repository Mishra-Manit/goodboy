{
  "name": "goodboy",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "npm run dev:dashboard & npm run dev:server",
    "build": "tsc && vite build --config dashboard/vite.config.ts",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "dev:server": "tsx watch src/index.ts",
    "dev:dashboard": "vite build --watch --config dashboard/vite.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:memory:cold": "tsx tests/scripts/run-memory-cold.ts",
    "test:memory:warm": "tsx tests/scripts/run-memory-warm.ts",
    "test:memory:clean": "tsx tests/scripts/clean-memory-tests.ts",
    "test:intent-latency": "tsx tests/scripts/run-telegram-intent-latency.ts",
    "dev:release-pr-session": "tsx scripts/dev-release-pr-session.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "@neondatabase/serverless": "^0.10.4",
    "@opentelemetry/api": "^1.9.1",
    "@pierre/diffs": "^1.1.20",
    "@pydantic/logfire-node": "^0.13.2",
    "@tailwindcss/typography": "^0.5.19",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.4",
    "grammy": "^1.35.0",
    "hono": "^4.7.4",
    "pi-subagents": "^0.15.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.30.4",
    "lucide-react": "^1.7.0",
    "msw": "^2.13.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^8.0.7",
    "vitest": "^4.1.5"
  }
}
